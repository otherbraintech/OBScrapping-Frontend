generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String          @id @default(cuid())
  name      String
  email     String          @unique
  password  String
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  scrapes   ScrapeRequest[]

  @@map("users")
}

model ScrapeRequest {
  id        String        @id @default(cuid())
  url       String
  network   String        @default("facebook")
  type      String        @default("reel")
  status    String        @default("pending")
  taskId    String?       @unique @map("task_id")
  userId    String        @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  result    ScrapeResult?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@map("scrape_requests")
}

model ScrapeResult {
  id          String        @id @default(cuid())
  contentType String        @default("unknown") @map("content_type")
  reactions   Int           @default(0)
  comments    Int           @default(0)
  shares      Int           @default(0)
  views       Int           @default(0)
  error       String?
  scrapedAt   DateTime?     @map("scraped_at")
  rawData     Json?         @map("raw_data")
  requestId   String        @unique @map("request_id")
  request     ScrapeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now()) @map("created_at")

  // Nueva relación para múltiples posts (cuando content_type == "page_feed")
  posts PostResult[]

  @@map("scrape_results")
}

model PostResult {
  id        String  @id @default(cuid())
  postId    String? @map("post_id") // ID interno de FB
  url       String? // URL directa de la publicación (/reel/ID/ o /posts/ID/)
  thumbnail String?
  caption   String? @db.Text

  // Métricas específicas de cada post
  reactions Int @default(0)
  comments  Int @default(0)
  shares    Int @default(0)
  views     Int @default(0)

  // Metadatos
  scrapedAt DateTime @default(now()) @map("scraped_at")

  // Relación con el resultado padre
  resultId String       @map("result_id")
  result   ScrapeResult @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@map("post_results")
}
